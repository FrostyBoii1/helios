# ============================================================================
# Helios Core — root environment template (used by docker-compose)
# Copy to .env and adjust. NEVER commit the real .env.
# ============================================================================

# ---- Environment ----
# One of: development | testing | production
ENVIRONMENT=development

# ---- PostgreSQL ----
POSTGRES_USER=helios
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=helios
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Backend ----
# Generate a strong value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=change_me_generate_a_long_random_value
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
# Comma-separated list of origins allowed to call the API
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- First admin (used by the seed script: `python -m app.seed`) ----
# Use a REAL, valid domain. email-validator rejects reserved domains like
# `.local`, so the backend will fail to start if you use one here.
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change_me_on_first_login
FIRST_ADMIN_NAME=System Administrator

# ---- File storage / NAS ----
# Absolute path INSIDE the backend container where the NAS share is mounted.
# Bind this to the real NAS path in docker-compose (see NAS_HOST_PATH).
NAS_ROOT=/data/nas
# Host path that gets mounted into the backend container at NAS_ROOT.
# For local dev this can be a folder on your machine; in production point it at the NAS share.
NAS_HOST_PATH=./nas_mount
# Where app-managed uploads live (also under a mounted volume in production)
STORAGE_ROOT=/data/storage
STORAGE_HOST_PATH=./storage

# ---- Frontend ----
# Base URL the browser uses to reach the API.
VITE_API_BASE_URL=http://localhost:8000/api/v1
