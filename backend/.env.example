# ============================================================================
# Backend-only environment template.
#
# When running via docker-compose these values come from the ROOT .env.
# This file is for running the backend directly (e.g. `uvicorn app.main:app`)
# outside Docker. Copy to backend/.env and adjust.
# ============================================================================

ENVIRONMENT=development

POSTGRES_USER=helios
POSTGRES_PASSWORD=change_me
POSTGRES_DB=helios
# When running outside Docker, the DB host is usually localhost.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

SECRET_KEY=change_me_generate_a_long_random_value
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Use a REAL, valid domain — email-validator rejects reserved domains like `.local`.
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change_me_on_first_login
FIRST_ADMIN_NAME=System Administrator

# Local dev paths (absolute or relative to the backend working directory)
NAS_ROOT=./nas_mount
STORAGE_ROOT=./storage
